# ============================================================
# server-tunning — Configuration
# ============================================================
# Copier ce fichier : cp .env.example .env
# Adapter les valeurs puis lancer : sudo bash setup.sh --env .env
# ============================================================

# ── Git ──────────────────────────────────────────────────────
KYC_GIT_REPO=https://github.com/your-org/your-app.git
KYC_GIT_BRANCH=main

# ── Application ─────────────────────────────────────────────
KYC_APP_USER=myapp
KYC_APP_DIR=/opt/myapp
KYC_SERVICE=myapp
KYC_PYTHON_VERSION=python3.9

# ── Serveur ──────────────────────────────────────────────────
KYC_BIND_HOST=0.0.0.0
KYC_BIND_PORT=8000

# ── Gunicorn ─────────────────────────────────────────────────
# "auto" = CPU / 3 (recommande pour workloads CPU-bound : OCR, IA, ML)
KYC_WORKERS=auto
KYC_TIMEOUT=120
KYC_MAX_REQUESTS=1000

# ── Infrastructure (2 serveurs + nginx LB) ───────────────────
KYC_SERVER1=192.168.1.10
KYC_SERVER2=192.168.1.11
KYC_NGINX_SERVER=192.168.1.10

# ── OS Tuning ────────────────────────────────────────────────
KYC_SWAP_SIZE=4G
