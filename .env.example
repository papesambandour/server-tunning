# ============================================================
# AI-YAS-KYC — Configuration deploiement
# ============================================================
# Copier ce fichier : cp .env.example .env
# Adapter les valeurs puis lancer : sudo bash setup.sh --env .env
# ============================================================

# ── Git ──────────────────────────────────────────────────────
KYC_GIT_REPO=https://github.com/votre-org/ai-yas-kyc.git
KYC_GIT_BRANCH=main

# ── Application ─────────────────────────────────────────────
KYC_APP_USER=kyc
KYC_APP_DIR=/opt/kyc
KYC_SERVICE=kyc
KYC_PYTHON_VERSION=python3.9

# ── Serveur ──────────────────────────────────────────────────
KYC_BIND_HOST=0.0.0.0
KYC_BIND_PORT=8000

# ── Gunicorn ─────────────────────────────────────────────────
# "auto" = CPU / 3 (recommande pour OCR CPU-bound)
KYC_WORKERS=auto
KYC_TIMEOUT=120
KYC_MAX_REQUESTS=1000

# ── Infrastructure (2 serveurs + nginx LB) ───────────────────
KYC_SERVER1=10.0.92.66
KYC_SERVER2=10.0.92.67
KYC_NGINX_SERVER=10.0.92.66

# ── OS Tuning ────────────────────────────────────────────────
KYC_SWAP_SIZE=4G
